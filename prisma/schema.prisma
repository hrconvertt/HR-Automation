  issuedDate   DateTime
  expiryDate   DateTime?
  credentialUrl String?
  createdAt    DateTime @default(now())

  @@map("certifications")
}

// ─── ASSETS ───────────────────────────────────────────────────────────────────

model Asset {
  id           String            @id @default(cuid())
  // Legacy display name + type (preserved for back-compat with the
  // existing AssetAssignment-driven UI; new imports populate `category`
  // / `subCategory` / `name` instead).
  name         String
  type         String            // LAPTOP | PHONE | MONITOR | CHAIR | OTHER
  brand        String?
  model        String?
  serialNo     String?           @unique
  purchaseDate DateTime?
  value        Float?
  status       String            @default("AVAILABLE") // AVAILABLE | ASSIGNED | MAINTENANCE | DISPOSED
  assignments  AssetAssignment[]
  createdAt    DateTime          @default(now())

  // ─── Workday-style asset register fields (added for the 996+
  //     spreadsheet import). All optional so existing rows continue
  //     to deserialize cleanly. ───────────────────────────────
  assetCode          String?   @unique   // user-supplied: STU-001 / FUR-002 / ELE-003 / WAT-001 …
  category           String?              // Electronic | Furniture | Equipments | Studio | Other
  subCategory        String?              // Laptop | AC | Bar Lights | etc.
  quantity           Int       @default(1)
  modelSerialNumber  String?
  motherboardNumber  String?
  estimatedLifeYears Float?
  purchasePricePkr   Float?
  currentMarketValue Float?
  residualValue      Float?
  photoUrl           String?              // Google Drive link
  photoBlob          Bytes?
  custodyType        String    @default("INDIVIDUAL") // INDIVIDUAL | SHARED | POOL
  locationLabel      String?              // "Kitchen" | "CEO Office" | "Studio" | …
  notes              String?
  isDemo             Boolean   @default(false)
  updatedAt          DateTime? @updatedAt

  @@map("assets")
}

model AssetAssignment {
  id           String    @id @default(cuid())
  assetId      String
  asset        Asset     @relation(fields: [assetId], references: [id])
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id])
  assignedDate DateTime
  returnedDate DateTime?
  condition    String?
  notes        String?
  createdAt    DateTime  @default(now())

  // ─── Typed asset details (Workday-style asset register) ───
  assetCode        String?   @unique   // CON-AST-NNN, auto-generated on add
  assetType        String?             // LAPTOP_DESKTOP | MOBILE_PHONE | SIM_CARD | ACCESS_CARD | OFFICE_KEYS | ID_CARD | SOFTWARE_LICENSE | EMAIL_ACCOUNT | MONITOR | HEADPHONES | KEYBOARD_MOUSE | LAPTOP_BAG | FURNITURE_CHAIR | VEHICLE | DOCUMENTS_CONTRACTS | OTHER
  brand            String?
  model            String?
  serialNumber     String?
  conditionAtIssue String?             // NEW | GOOD | USED | DAMAGED
  costPkr          Float?
  purchaseDate     DateTime?
  custodianDept    String?             // IT | Admin | HR
  photoBlob        Bytes?
  photoMimeType    String?
  returnCondition  String?
  returnPhotoBlob  Bytes?
  returnPhotoMime  String?
  isDemo           Boolean   @default(false)

  @@map("asset_assignments")
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────────

model EmployeeDocument {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  // Inverse relation for OnboardingTask.attachedDocument — populated when a
  // doc was uploaded specifically to satisfy an onboarding task.
  onboardingTaskAttachments OnboardingTask[] @relation("OnboardingTaskAttachment")
  type         String   // OFFER_LETTER | CNIC | RESUME | EDUCATIONAL_CERTIFICATE | EXPERIENCE | NDA | PHOTO | SALARY_SLIP | INCREMENT_LETTER | ONBOARDING_DOC | OTHER
  name         String
  url          String   @default("")
  size         Int?
  mimeType     String?
  uploadedById String?
  signedAt     DateTime?
  expiryDate   DateTime?
  // Postgres BYTEA storage — file bytes stored directly so we don't depend
  // on external blob storage during early deployments.
  fileBlob     Bytes?
  fileMimeType String?
  fileSize     Int?
  // HR can hide internal/HR-only documents (e.g. background-check report,
  // disciplinary record) from the employee's own view. Default true so
  // existing rows remain visible — HR explicitly opts out per-doc.
  visibleToEmployee Boolean @default(true)
  createdAt    DateTime @default(now())

  @@map("employee_documents")
}

model PolicyDocument {
  id              String    @id @default(cuid())
  title           String
  category        String    @default("GENERAL") // LEAVE | CODE_OF_CONDUCT | IT | SECURITY | COMPENSATION | GENERAL
  type            String    // HR_POLICY | LEAVE_POLICY | CODE_OF_CONDUCT | NDA_TEMPLATE | OTHER
  description     String?   // short summary shown in list
  content         String?   // full markdown / HTML body (in-app reading)
  url             String?   // optional PDF attachment
  version         String    @default("1.0")
  effectiveDate   DateTime?
  audience        String    @default("ALL")     // ALL | MANAGERS | HR_ONLY (legacy coarse audience — kept for back-compat)
  // Per-role audience (JSON-encoded array of role strings). HR controls who sees each policy.
  // Default: visible to every non-HR role. HR_ADMIN always sees every policy regardless.
  audienceRoles   String    @default("[\"EMPLOYEE\",\"LEAD\",\"MANAGER\",\"EXECUTIVE\",\"FINANCE\"]")
  requiresAck     Boolean   @default(false)
  // Workflow status:
  //   DRAFT     — HR writing it, no one else sees it
  //   IN_REVIEW — Submitted to a set of reviewers (Executives + HR admins)
  //   APPROVED  — All reviewers approved; awaiting HR activation
  //   ACTIVE    — Live, visible to its audience, an Announcement was created
  //   ARCHIVED  — Retired; hidden from non-HR
  //   (legacy "PUBLISHED" rows in existing DBs continue to work — read as ACTIVE)
  status          String    @default("ACTIVE")
  // Legacy publishedAt kept for backwards-compatibility (= activatedAt for new rows).
  publishedAt     DateTime?
  archivedAt      DateTime?
  // ─── Multi-stage approval workflow ───
  submittedForReviewAt   DateTime?
  submittedForReviewById String?
  reviewerIds            String[]  @default([])  // employees picked as reviewers (snapshot)
  approvedAt             DateTime?
  approvedById           String?
  rejectedAt             DateTime?
  rejectedById           String?
  rejectionReason        String?
  activatedAt            DateTime?
  activatedById          String?

  reviews                PolicyReview[]
  acknowledgments PolicyAcknowledgment[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("policy_documents")
}

// One PolicyReview row per (policy, reviewer). Reviewer can APPROVE or REJECT.
// When ALL rows for a policy reach APPROVED, the policy moves to APPROVED status.
// Any single REJECTED bounces it back to DRAFT.
model PolicyReview {
  id          String           @id @default(cuid())
  policy      PolicyDocument   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  policyId    String
  reviewer    Employee         @relation(fields: [reviewerId], references: [id])
  reviewerId  String
  status      String           @default("PENDING")  // PENDING | APPROVED | REJECTED
  comment     String?
  reviewedAt  DateTime?
  createdAt   DateTime         @default(now())

  @@unique([policyId, reviewerId])
  @@map("policy_reviews")
}

model PolicyAcknowledgment {
  id         String         @id @default(cuid())
  policyId   String
  policy     PolicyDocument @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employeeId String
  signedAt   DateTime?
  notifiedAt DateTime?
  reminderCount Int         @default(0)
  status     String         @default("PENDING") // PENDING | SIGNED

  @@unique([policyId, employeeId])
  @@map("policy_acknowledgments")
}

// ─── HR HELP DESK ─────────────────────────────────────────────────────────────

model HelpDeskTicket {
  id           String    @id @default(cuid())
  ticketId     String    @unique @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id])
  category     String    // PAYROLL | LEAVE | ATTENDANCE | POLICY | IT | OTHER
  subject      String
  description  String
  priority     String    @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  status       String    @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  assignedToId String?
  resolvedAt   DateTime?
  resolution   String?
  replies      TicketReply[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("help_desk_tickets")
}

model TicketReply {
  id        String         @id @default(cuid())
  ticketId  String
  ticket    HelpDeskTicket @relation(fields: [ticketId], references: [id])
  authorId  String
  message   String
  isInternal Boolean       @default(false)
  createdAt DateTime       @default(now())

  @@map("ticket_replies")
}

// ─── COMPLIANCE ───────────────────────────────────────────────────────────────

model ComplianceReport {
  id           String   @id @default(cuid())
  type         String   // EOBI | FBR_WITHHOLDING | PSEB | SOCIAL_SECURITY
  month        Int
  year         Int
  status       String   @default("DRAFT") // DRAFT | GENERATED | SUBMITTED
  fileUrl      String?
  submittedAt  DateTime?
  data         String?  // JSON blob of report data
  generatedById String?
  createdAt    DateTime @default(now())

  @@unique([type, month, year])
  @@map("compliance_reports")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  type        String   // LEAVE_APPROVED | PAYSLIP_READY | PROBATION_ALERT | REVIEW_DUE | TICKET_UPDATE | ANOMALY | GENERAL
  title       String
  message     String
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())

  @@map("notifications")
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  audience    String   @default("ALL") // ALL | HR | MANAGERS | DEPARTMENT
  departmentId String?
  isPinned    Boolean  @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime @default(now())

  @@map("announcements")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  action      String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | APPROVE | REJECT
  entity      String   // Employee | Payslip | LeaveRequest …
  entityId    String?
  oldValue    String?  // JSON
  newValue    String?  // JSON
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

// ─── EXIT CLEARANCE ───────────────────────────────────────────────────────────
// Unified offboarding workflow matching the Annexure E PDF.
// Five sections, each tracked with timestamp + signatory + cleared flag.
model ExitClearance {
  id                  String   @id @default(cuid())
  employeeId          String
  employee            Employee @relation(fields: [employeeId], references: [id])
  initiatedAt         DateTime @default(now())
  initiatedById       String?
  lastWorkingDay      DateTime?
  // Section 2 — departmental clearance
  itCleared           Boolean  @default(false)
  itClearedAt         DateTime?
  itClearedBy         String?
  financeCleared      Boolean  @default(false)
  financeClearedAt    DateTime?
  financeClearedBy    String?
  adminCleared        Boolean  @default(false)
  adminClearedAt      DateTime?
  adminClearedBy      String?
  hrCleared           Boolean  @default(false)
  hrClearedAt         DateTime?
  hrClearedBy         String?
  // Section 3 — settlement
  finalSettlementAmount Float?
  duesCleared           Boolean @default(false)
  settlementNotes       String?
  // Section 4 — employee declaration
  employeeAcknowledged Boolean @default(false)
  employeeSignedAt     DateTime?
  // Section 5 — HR certification
  hrCertifiedAt        DateTime?
  hrCertifiedById      String?
  // Final outputs
  clearanceFormLetterId String?
  relievingLetterId     String?
  experienceLetterId    String?
  // Auto-computed settlement components
  prorataSalary         Float?
  leaveEncashment       Float?
  outstandingDeductions Float?
  // Section 6 — Exit Interview
  interviewReason         String?
  interviewNextRole       String?
  interviewMgrSupport     Int?
  interviewWorkEnv        Int?
  interviewCompensation   Int?
  interviewGrowth         Int?
  interviewWorkLife       Int?
  interviewImprovement    String?
  interviewRecommendScore Int?
  interviewCompletedAt    DateTime?
  // Section 7 — Handover Document
  handoverCurrentProjects String?
  handoverPendingTasks    String?
  handoverKeyContacts     String?
  handoverDocLocations    String?
  handoverPasswords       String?
  handoverSignedAt        DateTime?
  handoverSignedByMgr     Boolean  @default(false)
  status               String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED
  completedAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("exit_clearances")
}

// ─── RESIGNATION ──────────────────────────────────────────────────────────────
// Self-serve resignation submission. Manager must acknowledge before
// HR opens an ExitClearance. Notice period is tracked, not enforced.
model Resignation {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  employee        Employee @relation(fields: [employeeId], references: [id])
  submittedAt     DateTime @default(now())
  intendedLastDay DateTime
  reason          String?
  managerAckedAt  DateTime?
  managerAckedById String?
  managerNotes    String?
  exitClearanceId String?
  status          String   @default("PENDING_MANAGER_ACK") // PENDING_MANAGER_ACK | ACKNOWLEDGED | RETRACTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("resignations")
}

// ─── MANAGER CHANGE AUDIT ─────────────────────────────────────────────────────
model ManagerHistory {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  oldManagerId    String?
  newManagerId    String?
  changedAt       DateTime @default(now())
  changedById     String
  reason          String?
  // ─── Role History extensions (F8) ─────────────────────────────────
  // Manual + editable role-history entries. When `title` is set the row
  // represents a Role History entry ("Promoted to Senior Designer"); when
  // null the row is a pure manager-reparenting record kept for backward
  // compat. `effectiveDate` defaults to `changedAt` for legacy rows.
  title           String?   // e.g. "Senior Designer"
  notes           String?   // free-form HR note shown on the row
  effectiveDate   DateTime? // when the change took effect (display date)
  isManual        Boolean   @default(false) // true = HR typed it; false = auto from reparent

  @@index([employeeId, changedAt])
  @@map("manager_history")
}

// ─── PROMOTION WORKFLOW ───────────────────────────────────────────────────────
// 3-step: Manager initiates -> HR approves -> CEO approves -> applied.
model PromotionRequest {
  id                   String   @id @default(cuid())
  employeeId           String
  employee             Employee @relation(fields: [employeeId], references: [id])
  initiatedById        String
  newDesignation       String
  newDepartmentId      String?
  newSalaryAmount      Float?
  effectiveDate        DateTime
  reason               String
  status               String   @default("PENDING_HR") // PENDING_HR | PENDING_CEO | APPROVED | REJECTED
  hrApprovedAt         DateTime?
  hrApprovedById       String?
  hrNotes              String?
  ceoApprovedAt        DateTime?
  ceoApprovedById      String?
  ceoNotes             String?
  letterId             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("promotion_requests")
}

// ─── ONBOARDING FEEDBACK (Day 30 survey) ──────────────────────────────────────
model OnboardingFeedback {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id])
  managerRating  Int?
  clarityRating  Int?
  missingItems   String?
  recommendScore Int?
  submittedAt    DateTime?
  createdAt      DateTime @default(now())

  @@map("onboarding_feedback")
}

// ─── SETTINGS / CONFIG ────────────────────────────────────────────────────────

model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("config")
}

// ─── Executive analytics inputs ─────────────────────────────────────
// HR enters the company's monthly revenue here so the CEO dashboard
// can compute Cost-of-People % and Revenue-per-Employee. We don't pull
// from accounting because Convertt's books live elsewhere (manual
// monthly input is honest and dead simple).
// ─── PEOPLE & CULTURE ─────────────────────────────────────────────────────────

model CompanyEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  eventDate   DateTime
  location    String?
  category    String   @default("GENERAL") // DINNER | TRIP | SPORTS | TRAINING | TOWN_HALL | EID | GENERAL
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("company_events")
}

model Kudos {
  id        String   @id @default(cuid())
  fromId    String
  from      Employee @relation("KudosFrom", fields: [fromId], references: [id])
  toId      String
  to        Employee @relation("KudosTo", fields: [toId], references: [id])
  message   String
  category  String   @default("APPRECIATION") // APPRECIATION | TEAMWORK | INNOVATION | LEADERSHIP
  createdAt DateTime @default(now())
  @@map("kudos")
}

// ─── EMAIL TEMPLATES ──────────────────────────────────────────────────────────

model EmailTemplate {
  id            String   @id @default(cuid())
  key           String   @unique
  // Template library fields (from email-template-library.json) — optional so
  // existing legacy templates (offer_letter etc) keep working unchanged.
  category      String?  // Recruitment | Onboarding | Employee Lifecycle | Performance | Payroll & Compensation | Offboarding | Culture & Engagement
  name          String?  // human-friendly name
  triggerEvent  String?  // e.g. "offer.accepted" — may contain " | " for multi-trigger
  condition     String?  // expression: "stage == 'shortlisted'" | "always" | etc
  delay         String?  // "immediate" | "2 hours" | etc
  channel       String   @default("email")
  manualReview  Boolean  @default(false)
  guards        String?  // JSON array of guard names
  active        Boolean  @default(true)
  // Existing fields
  subject       String
  body          String   @db.Text
  description   String?
  variables     String?  // JSON array OR legacy CSV
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
  sends         EmailSend[]
  @@index([triggerEvent])
  @@index([category])
  @@map("email_templates")
}

model EmailSend {
  id            String   @id @default(cuid())
  templateId    String
  template      EmailTemplate @relation(fields: [templateId], references: [id])
  // Recipient resolution
  toEmployeeId  String?
  toCandidateId String?
  toEmail       String
  subject       String
  body          String   @db.Text
  status        String   @default("DRAFT") // DRAFT | QUEUED | SENT | FAILED | SUPPRESSED
  scheduledFor  DateTime?
  sentAt        DateTime?
  failedReason  String?
  // Idempotency
  dedupeKey     String   @unique
  // Provenance
  eventName     String
  eventPayload  String?  @db.Text
  createdById   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([status])
  @@index([toEmployeeId])
  @@index([dedupeKey])
  @@map("email_sends")
}

// ─── TASK CATALOG ─────────────────────────────────────────────────────────────

model TaskTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  expectedHours   Float
  complexity      String   @default("MEDIUM")
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  assignments     TaskAssignment[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("task_templates")
}

model TaskAssignment {
  id                  String   @id @default(cuid())
  employeeId          String
  employee            Employee @relation(fields: [employeeId], references: [id])
  templateId          String?
  template            TaskTemplate? @relation(fields: [templateId], references: [id])
  customName          String?
  customExpectedHours Float?
  assignedAt          DateTime @default(now())
  assignedById        String?
  startedAt           DateTime?
  completedAt         DateTime?
  actualHours         Float?
  qualityScore        Float?
  delayReason         String?
  delayJustified      Boolean  @default(false)
  efficiency          Float?
  status              String   @default("ASSIGNED")
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@map("task_assignments")
}

model MonthlyMetric {
  id           String   @id @default(cuid())
  month        Int
  year         Int
  revenue      Float    // gross revenue for the month in PKR
  note         String?  // optional context ("Client X paid bonus", etc.)
  enteredById  String?  // User.id who logged this
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([month, year])
  @@map("monthly_metrics")
}

// ─── SIGN-UP ATTEMPT AUDIT ────────────────────────────────────────────────────
// When a Clerk sign-up email isn't on the allowlist, clerk-sync deletes the
// Clerk user immediately. Before deleting, we log a SignupAttempt row so HR
// can review and (a) approve the legitimate ones (e.g. someone joined with
// the wrong email) or (b) dismiss spam attempts.
model SignupAttempt {
  id              String    @id @default(cuid())
  email           String
  clerkUserId     String?
  firstName       String?
  lastName        String?
  attemptedAt     DateTime  @default(now())
  status          String    @default("PENDING") // PENDING | APPROVED | DISMISSED
  reviewedAt      DateTime?
  reviewedById    String?   // User.id of HR admin who acted
  reviewNotes     String?
  // When APPROVED, the newly-created User.id so HR can navigate to them.
  resultingUserId String?
  // Tracks last HR-notification fan-out so we don't spam the inbox
  // when the same email retries within 24h.
  lastNotifiedAt  DateTime?

  @@index([status])
  @@index([email])
  @@map("signup_attempts")
}

// ─── CULTURE NOTIFICATION CONFIG ──────────────────────────────────────────────
// Single-row settings table controlling fan-out scope for the celebration cron.
// Read by /api/cron/celebrations; managed at /dashboard/settings/culture-notifications.
model CultureNotificationConfig {
  id                            String   @id @default(cuid())
  birthdayNotificationScope     String   @default("TEAM_ONLY")     // TEAM_ONLY | COMPANY_WIDE
  anniversaryNotificationScope  String   @default("TEAM_ONLY")     // TEAM_ONLY | COMPANY_WIDE
  eventNotificationScope        String   @default("COMPANY_WIDE")  // COMPANY_WIDE (kept for future)
  updatedAt                     DateTime @updatedAt
  updatedById                   String?

  @@map("culture_notification_config")
}

// ─── LEADERSHIP DIRECT MESSAGES ───────────────────────────────────────────────
// Internal DM channel restricted to senior staff (HR_ADMIN, MANAGER, LEAD,
// EXECUTIVE + Head/Director/CTO/COO/CFO/Chief/Principal/Founder designations
// + LEAD+ position levels). Two-party only — group chats are out of scope.
// `threadKey` = sorted([senderId, recipientId]).join('|') so we can list
// conversations efficiently from either direction with a single index.
model DirectMessage {
  id          String    @id @default(cuid())
  senderId    String
  sender      Employee  @relation("DmSent", fields: [senderId], references: [id])
  recipientId String
  recipient   Employee  @relation("DmReceived", fields: [recipientId], references: [id])
  threadKey   String
  body        String    @db.Text
  sentAt      DateTime  @default(now())
  readAt      DateTime?
  editedAt    DateTime?
  deletedAt   DateTime?

  @@index([threadKey, sentAt])
  @@index([recipientId, readAt])
  @@map("direct_messages")
}

// ─── DAILY LOGGING + KPI TRACKING ─────────────────────────────────────────────
// Fully data-driven. HR configures the metric library, per-employee
// assignments, soft cutoffs, task categories, inquiry templates and
// analytics visibility from /dashboard/settings/daily-logging. Nothing
// is hardcoded — see src/lib/daily-logging-config.ts for the JSON blob
// stored under Config(key="daily_logging").

// HR-defined library of KPIs. May default-bind to a Position so HR can
// bulk-assign "Code Commits" to every Developer. Leads can still override
// per employee.
model KpiMetric {
  id                String          @id @default(cuid())
  name              String
  unit              String          @default("count") // count | hours | currency | percent
  description       String?
  isActive          Boolean         @default(true)
  defaultPositionId String?
  defaultPosition   Position?       @relation(fields: [defaultPositionId], references: [id])
  defaultTarget     Int?
  createdAt         DateTime        @default(now())
  createdById       String?
  assignments       KpiAssignment[]
  records           DailyKpi[]

  @@index([defaultPositionId])
  @@map("kpi_metrics")
}

// Which metrics apply to which employee + that employee's target.
model KpiAssignment {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  metricId     String
  metric       KpiMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  target       Int
  assignedById String?
  assignedAt   DateTime  @default(now())
  isActive     Boolean   @default(true)

  @@unique([employeeId, metricId])
  @@index([employeeId])
  @@map("kpi_assignments")
}

// Daily task log row + embedded Ask-Why inquiry loop.
model DailyLog {
  id                 String    @id @default(cuid())
  employeeId         String
  employee           Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date               DateTime  @db.Date
  taskName           String
  category           String?
  hoursInvested      Decimal   @db.Decimal(4, 2)
  status             String    @default("COMPLETED") // NOT_STARTED | IN_PROGRESS | COMPLETED | BLOCKED
  notes              String?
  // Inquiry loop
  inquiryStatus      String    @default("NONE") // NONE | PENDING | RESOLVED
  managerInquiry     String?
  managerInquiryAt   DateTime?
  managerInquiryById String?
  employeeResponse   String?
  employeeResponseAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([employeeId, date])
  @@index([inquiryStatus])
  @@map("daily_logs")
}

// Per (employee, date, metric) actuals + target snapshot + inquiry loop.
model DailyKpi {
  id                 String    @id @default(cuid())
  employeeId         String
  employee           Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  metricId           String
  metric             KpiMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  date               DateTime  @db.Date
  target             Int
  actual             Int
  inquiryStatus      String    @default("NONE")
  managerInquiry     String?
  managerInquiryAt   DateTime?
  managerInquiryById String?
  employeeResponse   String?
  employeeResponseAt DateTime?
  createdAt          DateTime  @default(now())

  @@unique([employeeId, metricId, date])
  @@index([employeeId, date])
  @@map("daily_kpis")
}
