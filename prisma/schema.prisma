generator client {
  provider = "prisma-client-js"
}

// Production: Postgres (Vercel Postgres / Neon / Supabase / self-hosted).
// Local dev: also Postgres — see scripts/setup-local-postgres.md, or run a
// Postgres container with `docker run -p 5432:5432 ...`. SQLite was used
// during early development but Vercel's serverless functions have an
// ephemeral filesystem, so we moved off it.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  // ─── Clerk integration (primary authentication source as of the Clerk migration) ───
  // Set on first sign-in via the Clerk webhook (see src/app/api/webhooks/clerk/route.ts)
  // or defensively by syncClerkUser() in src/lib/clerk-sync.ts.
  clerkUserId    String?   @unique
  password       String    // DEPRECATED — retained for rollback. Clerk owns auth now.
  role           String    @default("EMPLOYEE") // PRIMARY view (HR_ADMIN | MANAGER | LEAD | EMPLOYEE | EXECUTIVE | FINANCE) — used for default landing page
  userRoles      UserRole[]                     // FULL set of roles — Workday-style multi-role
  mustChangePass Boolean   @default(true)        // DEPRECATED — Clerk handles password resets
  isActive       Boolean   @default(true)
  lastLogin      DateTime?
  // ─── User preferences (Settings/Account) ───
  theme          String    @default("LIGHT")    // LIGHT | DARK | SYSTEM
  language       String    @default("EN")       // EN | UR | AR | HI | BN | ZH | ES | FR | DE | RU (most are placeholders — full translation rolling out)
  timezone       String    @default("Asia/Karachi")
  pronouns       String?
  notificationPrefs NotificationPreference[]
  employee       Employee?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("users")
}

// ─── Per-user notification preferences ──────────────────────────────────────
// One row per category × user. Missing rows = default (both channels enabled).
model NotificationPreference {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     String  // LEAVE | PROBATION | PERFORMANCE | DOCUMENTS | CELEBRATIONS | PAYROLL | LIFECYCLE
  emailEnabled Boolean @default(true)
  inAppEnabled Boolean @default(true)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([userId, category])
  @@map("notification_preferences")
}

// ─── Multi-role membership (Workday-style) ──────────────────────────────────
// A user can hold multiple roles at once (e.g. Manager + Employee + HR Partner).
// The role on User.role is the primary/default view; this table is the full set.
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // HR_ADMIN | MANAGER | LEAD | EMPLOYEE | EXECUTIVE | FINANCE
  assignedAt DateTime @default(now())
  assignedBy String?  // userId of who granted this role

  @@unique([userId, role])
  @@map("user_roles")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

// ─── ORGANISATION ────────────────────────────────────────────────────────────

model Department {
  id          String     @id @default(cuid())
  code        String     @unique // BD, UIUX, WBS …
  name        String
  headId      String?
  employees   Employee[]
  positions   Position[]
  taskTemplates TaskTemplate[]
  createdAt   DateTime   @default(now())

  @@map("departments")
}

model Position {
  id           String     @id @default(cuid())
  title        String
  // INTERN | JUNIOR | EXECUTIVE | ASSOCIATE | SENIOR | LEAD | MANAGER | HEAD | DIRECTOR | C_SUITE
  level        String
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  description  String?
  active       Boolean    @default(true)
  employees    Employee[]
  salaryBands  SalaryBand[]
  kpiDefaults  KpiMetric[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt @default(now())

  @@unique([title, departmentId])
  @@map("positions")
}

// ─── EMPLOYEES ───────────────────────────────────────────────────────────────

model Employee {
  id                  String    @id @default(cuid())
  employeeCode        String    @unique // CON-BD-007 (system-generated sequential per dept)
  legacyEmployeeCode  String?              // Original code from master sheet — preserved as backup
  userId              String?   @unique
  user                User?     @relation(fields: [userId], references: [id])

  // Personal
  fullName            String
  email               String    @unique
  phone               String?
  cnic                String?
  dob                 DateTime?
  gender              String?
  address             String?    // Permanent / home address
  temporaryAddress    String?    // Temporary / current address (if different from home)
  workLocationAddress String?    // Office address or remote-work address
  emergencyContact    String?
  emergencyPhone      String?
  emergencyRelation   String?
  emergencyEmail      String?
  photoUrl            String?

  // ─── Extended personal info (enriched from BPM / Employee Info forms) ───
  // All nullable — no migration risk to existing rows.
  maritalStatus       String?   // Single | Married | Divorced | Widowed
  fatherOrHusbandName String?
  mothersMaidenName   String?
  cnicIssuedOn        DateTime?
  cnicExpiresOn       DateTime?
  cnicBirthDate       DateTime? // CNIC-stated DOB (may differ from `dob`)
  placeOfBirth        String?
  cityOfBirth         String?
  placeOfIssuance     String?
  nationalityCountry  String?   // defaults to "Pakistan" when populated
  homePhone           String?
  officePhone         String?
  bankAccountName     String?   // account title — name on the bank account

  // Job
  joiningDate         DateTime
  confirmationDate    DateTime?
  exitDate            DateTime?
  // For Executive dashboard analytics — voluntary vs forced attrition
  // is the metric a CEO actually cares about, not raw exit count.
  //   VOLUNTARY     — resigned of own choice (regret)
  //   INVOLUNTARY   — terminated (performance, misconduct, layoff)
  //   END_OF_CONTRACT — internship / contract finished naturally
  //   null          — still employed
  terminationType     String?   // VOLUNTARY | INVOLUNTARY | END_OF_CONTRACT
  designation         String
  hiringDesignation   String?
  departmentId        String?
  department          Department? @relation(fields: [departmentId], references: [id])
  positionId          String?
  position            Position?   @relation(fields: [positionId], references: [id])
  reportingManagerId  String?
  reportingManager    Employee?   @relation("Reports", fields: [reportingManagerId], references: [id])
  directReports       Employee[]  @relation("Reports")
  employeeType        String      @default("PROBATION") // PERMANENT | PROBATION | INTERNSHIP | TRAINING
  status              String      @default("ACTIVE")    // ACTIVE | PROBATION | ON_LEAVE | RESIGNED | TERMINATED | LAYOFF | INACTIVE
  workLocation        String      @default("ONSITE")    // ONSITE | WFH | HYBRID
  timings             String?
  workDays            String      @default("Mon,Tue,Wed,Thu,Fri") // comma-separated: Mon,Tue,Wed,Thu,Fri,Sat,Sun

  // Bank & Compensation
  bankName            String?
  bankAccount         String?
  bankBranch          String?
  ibanAccount         String?  // IBAN format account # from payroll IBFT sheets
  salary              Salary?

  // Statutory / Tax Identifiers (Pakistan)
  //   eobiNumber — Employees' Old-age Benefits Institution registration
  //   ntn        — National Tax Number (FBR)
  //   sessiNumber— Sindh Employees' Social Security Institution (provincial; optional)
  // All HR-only on read for managers; visible to HR + the employee themselves.
  eobiNumber          String?
  ntn                 String?
  sessiNumber         String?

  // Directory visibility
  //   hideFromDirectory — when true, this employee is hidden from the
  //   Employee-role "Company Directory" view ONLY. HR, the assigned manager,
  //   and the employee themselves can always see the record. Use sparingly:
  //   protected leave, pre-announcement hires, or sensitive isolation cases.
  hideFromDirectory   Boolean   @default(false)
  // Personal celebration privacy — when true, this employee opts out of
  // having their birthday / anniversary surfaced in calendars, the
  // People & Culture module, "This Week Ahead" widget, and the daily
  // celebration cron. HR is the only role that can still query these.
  hideBirthday        Boolean   @default(false)
  hideAnniversary     Boolean   @default(false)
  isDemo              Boolean   @default(false)

  // Relations
  attendanceLogs      AttendanceLog[]
  leaveBalances       LeaveBalance[]
  leaveRequests       LeaveRequest[]
  payslips            Payslip[]
  performanceReviews  PerformanceReview[]
  goals               Goal[]
  onboarding          OnboardingChecklist?
  probation           ProbationRecord?
  assets              AssetAssignment[]
  documents           EmployeeDocument[]
  helpDeskTickets     HelpDeskTicket[]
  employeeWarnings    EmployeeWarning[] @relation("EmployeeWarnings")
  celebrationCards    CelebrationCard[] @relation("CelebrationCards")
  notifications       Notification[]
  compensationHistory CompensationHistory[]
  trainingRecords     TrainingRecord[]
  showCauses          ShowCause[]
  pips                PIP[]
  jobOffers           JobOffer[]
  hiringRequests      JobRequisition[] @relation("HiringRequests")  // requisitions this manager raised
  auditLogs           AuditLog[]
  trustedDevices      TrustedDevice[]
  journeys            EmployeeJourney[]
  emailDrafts         EmailDraft[]
  letterRequests      LetterRequest[]
  exitClearances      ExitClearance[]
  kudosGiven          Kudos[]           @relation("KudosFrom")
  kudosReceived       Kudos[]           @relation("KudosTo")
  tasks               TaskAssignment[]
  resignation         Resignation?
  managerHistory      ManagerHistory[]
  promotionRequests   PromotionRequest[]
  onboardingFeedback  OnboardingFeedback?
  policyReviews       PolicyReview[]
  dmsSent             DirectMessage[]   @relation("DmSent")
  dmsReceived         DirectMessage[]   @relation("DmReceived")
  kpiAssignments      KpiAssignment[]
  dailyLogs           DailyLog[]
  dailyKpis           DailyKpi[]

  // Rehire / boomerang
  rehireDate          DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("employees")
}

// ─── DOCUMENTS & LETTERS ──────────────────────────────────────────────────────
// Self-serve formal letter issuance: employees request, HR reviews & generates.

model LetterRequest {
  id                 String    @id @default(cuid())
  letterNumber       String?   @unique           // CON-LTR-YYYY-NNN, assigned on approval
  employeeId         String
  employee           Employee  @relation(fields: [employeeId], references: [id])
  letterType         String    // EXPERIENCE | SALARY_CERTIFICATE | NOC_VISA | BONAFIDE | RELIEVING
  purpose            String?   // free text: "for HBL home loan application"
  destinationCountry String?   // for NOC_VISA
  bankName           String?   // for SALARY_CERTIFICATE
  travelFrom         DateTime? // for NOC_VISA
  travelTo           DateTime? // for NOC_VISA
  status             String    @default("PENDING") // PENDING | APPROVED | REJECTED | GENERATED
  rejectionReason    String?
  requestedAt        DateTime  @default(now())
  reviewedAt         DateTime?
  reviewedById       String?   // userId of HR admin
  signedByName       String?   // who signs on company side
  signedByTitle      String?
  letterBody         String?   // generated text snapshot
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("letter_requests")
}

// ─── ATTENDANCE ───────────────────────────────────────────────────────────────

// Each individual in/out tap during a day. Multiple per day = lunch breaks, errands.
// The summary fields on AttendanceLog (clockIn / clockOut / hoursWorked) are
// recomputed from these every time a punch is added.
model AttendancePunch {
  id            String   @id @default(cuid())
  employeeId    String
  date          DateTime // calendar day (midnight UTC) for grouping
  type          String   // IN | OUT
  timestamp     DateTime
  workType      String?  // ONSITE | WFH (set on each IN, inherited by following OUT)
  ipAddress     String?
  deviceHash    String?
  trustScore    Int?
  riskFlags     String?  // JSON array
  source        String?  // BROWSER | MOBILE | DEVICE | MANUAL
  notes         String?  // e.g. "lunch break", "client meeting"
  createdAt     DateTime @default(now())

  @@index([employeeId, date, timestamp])
  @@map("attendance_punches")
}

model TimesheetEntry {
  id          String   @id @default(cuid())
  employeeId  String
  date        DateTime @db.Date
  category    String?
  hours       Decimal  @db.Decimal(4, 2)
  taskId      String?
  notes       String?
  createdAt   DateTime @default(now())
  @@index([employeeId, date])
  @@map("timesheet_entries")
}

model AttendanceLog {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id])
  date         DateTime
  clockIn      DateTime?
  clockOut     DateTime?
  workType     String    // ONSITE | WFH
  hoursWorked  Float?
  status       String    // PRESENT | ABSENT | LATE | HALF_DAY | HOLIDAY | WEEKEND | LEAVE
  lateMinutes       Int?
  overtimeHours     Float    @default(0)
  overtimeApproved  Boolean  @default(false)
  overtimeApprovedById String?
  notes             String?
  ipAddress         String?

  // ─── Clock-in security (Workday-style trust scoring) ───
  clockInIp           String?
  clockInDeviceHash   String?
  clockInLat          Float?
  clockInLng          Float?
  clockInSsid         String?
  clockInLocationId   String?
  clockInTrustScore   Int?      // 0–100
  clockInRiskFlags    String?   // JSON array: ["UNKNOWN_DEVICE","OUTSIDE_GEOFENCE",...]
  clockInSource       String?   // BROWSER | MOBILE | DEVICE | MANUAL

  clockOutIp          String?
  clockOutDeviceHash  String?
  clockOutLat         Float?
  clockOutLng         Float?
  clockOutTrustScore  Int?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([employeeId, date])
  @@map("attendance_logs")
}

// ─── CLOCK-IN SECURITY ────────────────────────────────────────────────────────

model Location {
  id            String   @id @default(cuid())
  name          String   // e.g. "Convertt HQ — Gulberg"
  kind          String   @default("OFFICE") // OFFICE | REMOTE_HOME | FIELD
  // Network rules — JSON arrays so SQLite stays simple
  ipCidrs       String   @default("[]")   // ["203.0.113.0/24","2.2.2.2/32"]
  ssids         String   @default("[]")   // ["Convertt-Office","Convertt-Guest"]
  // Geofence
  lat           Float?
  lng           Float?
  radiusMeters  Int?     @default(200)
  // Lifecycle
  active        Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("locations")
}

model TrustedDevice {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  deviceHash   String    // stable hash of UA + screen + canvas + accept-lang
  label        String?   // employee-set label e.g. "Work MacBook"
  userAgent    String?
  status       String    @default("TRUSTED") // TRUSTED | PENDING | REVOKED
  firstSeenAt  DateTime  @default(now())
  lastUsedAt   DateTime  @default(now())
  trustedAt    DateTime?
  trustedBy    String?   // userId of HR/manager who approved
  revokedAt    DateTime?

  @@unique([employeeId, deviceHash])
  @@map("trusted_devices")
}

/// Company holidays. Days where `type=PUBLIC` are paid and are skipped by
/// countWorkingDays so they don't burn an employee's leave balance.
model Holiday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime @unique
  type        String   // PUBLIC | OPTIONAL | COMPANY
  createdAt   DateTime @default(now())

  @@map("holidays")
}

// ─── LEAVE ────────────────────────────────────────────────────────────────────

model LeavePolicy {
  id           String   @id @default(cuid())
  employeeType String   // PERMANENT | PROBATION | INTERNSHIP | TRAINING
  leaveType    String   // CASUAL | SICK | EARNED | ANNUAL | MATERNITY | PATERNITY | UNPAID
  daysPerYear  Int
  // For PROBATION/INTERNSHIP/TRAINING types we accrue per month worked
  // rather than handing out the full quota up-front. 1.0 = one day per
  // month. Null means "use daysPerYear as a one-shot allocation"
  // (PERMANENT default behaviour).
  accrualPerMonth Float?
  carryForward Boolean  @default(false)
  maxCarryDays Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeType, leaveType])
  @@map("leave_policies")
}

model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  year        Int
  leaveType   String   // CASUAL | SICK | EARNED | ANNUAL | MATERNITY | PATERNITY | UNPAID
  // Float so half-day requests (0.5) accumulate correctly. Two half-days = 1.
  allocated   Float
  used        Float    @default(0)
  pending     Int      @default(0)
  remaining   Float

  @@unique([employeeId, year, leaveType])
  @@map("leave_balances")
}


model LeaveRequest {
  id           String    @id @default(cuid())
  requestId    String    @unique @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id])
  leaveType    String
  fromDate     DateTime
  toDate       DateTime
  // `days` is now Float — supports half-days (0.5, 1.5, 2.5, etc.)
  days         Float
  // Half-day flags — apply to the FIRST and/or LAST day of the requested range
  firstDayHalf Boolean   @default(false)
  lastDayHalf  Boolean   @default(false)
  reason       String
  // Two-stage approval workflow:
  //   PENDING     — submitted, awaiting reporting manager's first decision
  //   PENDING_HR  — manager approved, awaiting HR's final sign-off
  //   APPROVED    — HR finalised, leave balance deducted
  //   REJECTED    — rejected by manager or HR at any stage (terminal)
  //   CANCELLED   — withdrawn by the employee while still pending
  status       String    @default("PENDING")
  // First-stage (manager) approver — set when the manager approves
  managerApprovedById String?
  managerApprovedAt   DateTime?
  // Override of the default reportingManager-based stage-1 approver.
  // Set on submit when the requester is senior staff (Manager / Lead /
  // Head / Director / CTO / COO / C-suite) — those route through the
  // Co-Founder instead of their reportingManager. Nullable for backwards
  // compat with rows created before this field existed.
  stageOneApproverId  String?
  // Final approver (HR) — set when HR finalises the request
  approvedById String?
  approvedAt   DateTime?
  rejectedReason String?
  rejectedById   String?
  attachmentUrl  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("leave_requests")
}

// ─── PAYROLL ──────────────────────────────────────────────────────────────────

model Salary {
  id           String   @id @default(cuid())
  employeeId   String   @unique
  employee     Employee @relation(fields: [employeeId], references: [id])
  basic        Float
  houseRent    Float    @default(0)
  utilities    Float    @default(0)
  food         Float    @default(0)
  fuel         Float    @default(0)
  medicalAllowance Float @default(0)
  otherAllowance   Float @default(0)
  effectiveFrom DateTime
  // Day-of-month salary is paid (e.g. 5 = paid on the 5th). HR-configurable per
  // employee — most Convertt staff are paid on the 5th, but contractors and
  // legacy hires sometimes have different cycles.
  monthlyPayDay Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("salaries")
}

model SalaryBand {
  id         String    @id @default(cuid())
  positionId String
  position   Position  @relation(fields: [positionId], references: [id])
  minSalary  Float
  maxSalary  Float
  currency   String    @default("PKR")
  effectiveFrom DateTime
  createdAt  DateTime  @default(now())

  @@map("salary_bands")
}

model PayrollRun {
  id            String    @id @default(cuid())
  month         Int
  year          Int
  // Active multi-stage flow (HR-driven, replaces legacy 8-stage Workday chain):
  //   DRAFT → PENDING_CEO → PENDING_HR_FINAL → PENDING_FINANCE → PAID
  //   (Plus REJECTED + Send-Back returns one stage with a reason.)
  //
  // Legacy values still in DB on historical rows: CALCULATED, MANAGER_CONFIRMED,
  // FINANCE_REVIEWED, APPROVED, LOCKED, DISBURSED, CLOSED — all treated as
  // completed/historical (effectively PAID) by the new UI. Migrate via
  // scripts/migrate-payroll-status.js.
  status        String    @default("DRAFT")
  totalGross    Float     @default(0)
  totalNet      Float     @default(0)
  totalEOBI     Float     @default(0)
  totalTax      Float     @default(0)
  // Approval tracking — legacy fields (kept for back-compat + read by old reports)
  calculatedAt        DateTime?
  managerConfirmedAt  DateTime?
  financeReviewedAt   DateTime?
  approvedById        String?
  approvedAt          DateTime?
  lockedAt            DateTime?
  disbursedAt         DateTime?
  closedAt            DateTime?
  sentAt              DateTime?
  // ─── New 5-stage approval timeline ───
  submittedToCeoAt    DateTime?
  submittedToCeoById  String?
  ceoReviewedAt       DateTime?
  ceoReviewedById     String?
  ceoNotes            String?
  returnedToHrAt      DateTime?
  hrFinalApprovedAt   DateTime?
  hrFinalApprovedById String?
  releasedToFinanceAt DateTime?
  financePaidAt       DateTime?
  financePaidById     String?
  // Send-Back — captures the most recent send-back; full history is in PayrollRunApproval
  sendBackReason      String?
  sendBackAt          DateTime?
  sendBackById        String?
  payslips            Payslip[]
  approvals           PayrollRunApproval[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([month, year])
  @@map("payroll_runs")
}

model PayrollRunApproval {
  id            String   @id @default(cuid())
  runId         String
  run           PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  fromStatus    String   // status before the action
  toStatus      String   // status after the action
  action        String   // CALCULATE | CONFIRM | REVIEW | APPROVE | REJECT | LOCK | DISBURSE | CLOSE | RECALL
  actorUserId   String   // user.id who performed the action
  actorName     String?  // snapshot for audit (in case user is deleted)
  actorRole     String?  // role at time of action (HR_ADMIN, MANAGER, FINANCE, EXECUTIVE)
  comment       String?
  createdAt     DateTime @default(now())

  @@index([runId, createdAt])
  @@map("payroll_run_approvals")
}

model Payslip {
  id              String     @id @default(cuid())
  employeeId      String
  employee        Employee   @relation(fields: [employeeId], references: [id])
  payrollRunId    String?
  payrollRun      PayrollRun? @relation(fields: [payrollRunId], references: [id])
  month           Int
  year            Int
  basic           Float
  houseRent       Float      @default(0)
  utilities       Float      @default(0)
  food            Float      @default(0)
  fuel            Float      @default(0)
  medicalAllowance Float     @default(0)
  otherAllowance  Float      @default(0)
  bonus           Float      @default(0)
  overtimePay     Float      @default(0)
  // HR-overridable line items — set via "Adjust Payslip" dialog.
  // Survive recompute when isAdjusted=true.
  leaveEncashment Float      @default(0)
  arrears         Float      @default(0)  // back-dated unpaid amount owed
  grossSalary     Float
  eobi            Float      @default(0)
  incomeTax       Float      @default(0)
  providentFund   Float      @default(0)  // HR-overridable (PF / EPF deduction)
  healthcare      Float      @default(0)  // employee's health-insurance contribution
  loanDeduction   Float      @default(0)  // monthly instalment for company loan / vehicle
  vehicleDeduction Float     @default(0)  // company vehicle / fuel-card recovery
  advanceDeduction Float     @default(0)  // recovery of a salary advance
  otherDeductions Float      @default(0)
  lateDeduction   Float      @default(0)   // late / leave-based deduction surfaced in grid
  netSalary       Float
  // Bank-payout override — grid lets HR override the value that goes to the bank
  // file independent of netSalary. Falls back to netSalary when null.
  transactionAmount Float?
  // Auto-set bank reference text ("Salary <Month> <Year>"). Stored so exports
  // are stable even if month/year format changes.
  reference         String?
  // HR-editable free-text note attached to the bank row (e.g. "Bank Acc Pend")
  payoutNotes       String?
  // Adjustment audit
  isAdjusted      Boolean    @default(false) // HR has manually edited this row; Recompute will skip it
  adjustmentNote  String?                    // Free-text reason ("March bonus", "10 days encashed")
  adjustedBy      String?                    // userId of the HR who last edited
  adjustedAt      DateTime?
  workingDays     Int
  presentDays     Int
  leaveDays       Int        @default(0)
  absentDays      Int        @default(0)
  status          String     @default("DRAFT") // DRAFT | PENDING_APPROVAL | APPROVED | SENT
  pdfUrl          String?
  sentAt          DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([employeeId, month, year])
  @@map("payslips")
}

model CompensationHistory {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  type         String   // INCREMENT | PROMOTION | BONUS | ADJUSTMENT
  oldSalary    Float
  newSalary    Float
  incrementPct Float?
  reason       String?
  notes        String?  // Free-form manager comment shown on the increment letter
  effectiveDate DateTime
  approvedById String?
  createdAt    DateTime @default(now())

  @@map("compensation_history")
}

// ─── PERFORMANCE ──────────────────────────────────────────────────────────────

model Goal {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  goalId       String
  description  String
  kpi          String?
  target       String?
  weight       Float    @default(0)
  status       String   @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | ON_TRACK | AT_RISK | COMPLETED
  selfComment  String?
  managerComment String?
  achievement  Float?
  reviewId     String?
  review       PerformanceReview? @relation(fields: [reviewId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("goals")
}

model PerformanceReview {
  id                String   @id @default(cuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id])
  reviewerId        String?
  reviewPeriod      String
  reviewType        String   // BIANNUAL | ANNUAL | PROBATION  (legacy values: MONTHLY_11, QUARTERLY)
  selfRating        Float?
  managerRating     Float?
  teamworkScore     Float?
  ownershipScore    Float?
  communicationScore Float?
  reliabilityScore  Float?
  initiativeScore   Float?
  adaptabilityScore Float?
  behavioralAvg     Float?
  individualScore   Float?
  teamScore         Float?
  overallRating     Float?
  finalCategory     String?  // EXCEEDS | MEETS | BELOW | UNSATISFACTORY
  achievements      String?
  learnings         String?
  teamContribution  String?
  managerFeedback   String?
  status            String   @default("PENDING") // PENDING | SELF_SUBMITTED | MANAGER_REVIEWED | HR_CALIBRATED | HR_FINALIZED | RELEASED

  // HR calibration step — between MANAGER_REVIEWED and HR_FINALIZED, HR can
  // normalise overall ratings across managers + add calibration notes. Then
  // "Release Reviews" releases the whole cycle to employees in one batch.
  calibratedAt      DateTime?
  calibrationNotes  String?
  releasedAt        DateTime?  // set when the cycle is released to employees

  // ─── Time & Work auto-metrics (computed from Attendance + Goals over cycle window) ───
  cycleStartDate    DateTime?
  cycleEndDate      DateTime?
  daysWorked        Int?
  daysAbsent        Int?
  daysOnLeave       Int?
  lateArrivalCount  Int?
  avgHoursPerDay    Float?
  goalsOnTime       Int?
  goalsLate         Int?
  timeScore         Float?

  goals             Goal[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("performance_reviews")
}

// Performance concern workflow:
//   1. MEETING_REQUESTED — manager flags a pattern, requests 1:1 with employee
//   2. MEETING_HELD       — meeting outcome logged
//   3. SHOW_CAUSE_REQUESTED — manager escalates because pattern persists
//   4. ISSUED              — HR has issued the formal Show Cause Notice
//   5. RESPONDED           — employee submitted their written response
//   6. RESOLVED | ESCALATED_TO_PIP — final outcome
model ShowCause {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  issueType     String   // ATTENDANCE | MISCONDUCT | PERFORMANCE | OTHER

  // Manager-initiated meeting stage
  requestedById       String?   // userId of manager who flagged it
  requestedByName     String?   // snapshot
  meetingRequestedAt  DateTime?
  meetingScheduledFor DateTime?
  meetingConcerns     String?   // initial reasons / pattern observed
  meetingHeldAt       DateTime?
  meetingNotes        String?   // what was discussed + commitments

  // Escalation to HR for formal show cause
  escalationRequestedAt DateTime?
  escalationReason      String?   // why the pattern persists after meeting

  // Issued (formal Show Cause Notice)
  issueDate     DateTime?
  description   String?   // formal notice text (auto-populated from meetingConcerns + escalationReason)
  deadline      DateTime?
  issuedBy      String?
  occurrenceNo  Int      @default(1)

  // Employee response
  employeeResponse String?
  responseAt       DateTime?

  // Outcome
  actionPlan    String?
  followUpDate  DateTime?
  outcome       String?

  // Severity label — surfaced on the Show Cause card, drives default deadline length
  severity      String   @default("MINOR") // MINOR | MODERATE | SEVERE

  // Cross-module linkage. Lets a ShowCause point back to the source that
  // triggered it. Format: `<MODULE>:<id>` e.g. "PROBATION:cuid_xxx",
  // "PERFORMANCE_REVIEW:cuid_xxx", "ATTENDANCE_PATTERN:2026-01_2026-02".
  // The UI links back to the source on the ShowCause detail page.
  relatedRef    String?

  // Stage machine
  status        String   @default("MEETING_REQUESTED") // MEETING_REQUESTED | MEETING_HELD | SHOW_CAUSE_REQUESTED | ISSUED | RESPONDED | RESOLVED | ESCALATED_TO_PIP | ESCALATED_TERMINATION

  isDemo        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("show_causes")
}

// Lightweight Warning record — issued by Manager / HR for minor infractions
// before any formal Show Cause. Auto-escalates to ShowCause on the 3rd row
// per employee (see /api/performance/warnings POST handler).
model EmployeeWarning {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation("EmployeeWarnings", fields: [employeeId], references: [id])
  issuedById  String
  reason      String
  category    String   @default("OTHER") // ATTENDANCE | CONDUCT | PERFORMANCE | OTHER
  severity    String   @default("VERBAL") // VERBAL | WRITTEN | FINAL
  letterId    String?  // FK to generated warning letter, if any
  isDemo      Boolean  @default(false)
  issuedAt    DateTime @default(now())

  @@map("employee_warnings")
}

// Celebration card — teammates leave signatures/messages on an upcoming
// birthday or anniversary; on the day, the compiled card is shown to
// the recipient. Minimum-viable comment-thread model.
model CelebrationCard {
  id            String   @id @default(cuid())
  forEmployeeId String
  forEmployee   Employee @relation("CelebrationCards", fields: [forEmployeeId], references: [id])
  occasion      String   // BIRTHDAY | ANNIVERSARY_1YR | ANNIVERSARY_3YR | …
  occasionDate  DateTime
  status        String   @default("OPEN")  // OPEN | DELIVERED
  signatures    CelebrationCardSignature[]
  createdAt     DateTime @default(now())

  @@map("celebration_cards")
}

model CelebrationCardSignature {
  id        String          @id @default(cuid())
  cardId    String
  card      CelebrationCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fromId    String
  message   String
  createdAt DateTime        @default(now())

  @@map("celebration_card_signatures")
}

model PIP {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  startDate    DateTime
  endDate      DateTime
  objectives   String
  metrics      String
  checkIns     String?
  outcome      String?  // PASSED | FAILED | IN_PROGRESS
  managerId    String?
  hrId         String?
  isDemo       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("pips")
}

// ─── ONBOARDING & PROBATION ───────────────────────────────────────────────────

model OnboardingChecklist {
  id                    String    @id @default(cuid())
  employeeId            String    @unique
  employee              Employee  @relation(fields: [employeeId], references: [id])
  welcomeEmailSent      Boolean   @default(false)
  firstDayCompleted     Boolean   @default(false)
  offerLetterIssued     Boolean   @default(false)
  agreementSigned       Boolean   @default(false)
  cnicCopied            Boolean   @default(false)
  bankDetailsCollected  Boolean   @default(false)
  educationDocsCopied   Boolean   @default(false)
  experienceLettersCopied Boolean @default(false)
  ndaSigned             Boolean   @default(false)
  photoTaken            Boolean   @default(false)
  systemAccessGranted   Boolean   @default(false)
  equipmentIssued       Boolean   @default(false)
  introductionDone      Boolean   @default(false)
  status                String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETED
  completedAt           DateTime?
  notes                 String?
  // Day 1 schedule template, free-form (markdown / plain text / JSON)
  day1ScheduleJson      String?
  // Welcome email auto-send scheduling
  welcomeEmailScheduledFor DateTime?
  welcomeEmailSentAt    DateTime?
  // Custom tasks per-hire (preferred over fixed booleans for new flows)
  tasks                 OnboardingTask[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("onboarding_checklists")
}

// Per-hire custom onboarding task — replaces the fixed boolean list.
// One OnboardingChecklist has many tasks across categories.
model OnboardingTask {
  id            String   @id @default(cuid())
  checklistId   String
  checklist     OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  owner         String   // HR | MANAGER | EMPLOYEE | IT
  category      String   // DAY_1 | WEEK_1_PAPERWORK | WEEK_1_IT | PRE_ARRIVAL | OTHER
  orderIndex    Int      @default(0)
  isComplete    Boolean  @default(false)
  completedAt   DateTime?
  completedById String?
  notes         String?
  // Employee self-service flag — true for the 5 employee-provided docs
  // (CNIC, Photo, Address Proof, Education Cert, Experience Letter).
  // The employee profile renders an upload widget for each task with
  // this flag set; uploading flips isComplete to true automatically.
  isEmployeeUploadable Boolean @default(false)
  // Maps the task to an EmployeeDocument.type so the upload widget
  // knows which slot to populate (e.g. "CNIC", "PHOTO", "EDUCATIONAL_CERTIFICATE").
  documentType  String?
  // Workday-style state machine. isComplete is kept in sync for legacy code
  // paths; new code should branch on `status` instead.
  // PENDING | IN_PROGRESS | COMPLETED | NOT_REQUIRED
  status            String   @default("PENDING")
  notRequiredReason String?
  // When the task was completed by attaching a document, this points to the
  // EmployeeDocument row (which carries the BYTEA payload).
  attachedDocumentId String?
  attachedDocument   EmployeeDocument? @relation("OnboardingTaskAttachment", fields: [attachedDocumentId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([checklistId, category, orderIndex])
  @@map("onboarding_tasks")
}

// ─── EMPLOYEE JOURNEYS (Onboarding / Offboarding) ─────────────────────────────
// Workday-style task-driven Business Process for joining + leaving events.

model EmployeeJourney {
  id              String        @id @default(cuid())
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type            String        // ONBOARDING | OFFBOARDING
  status          String        @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | CANCELLED
  // Offboarding-specific
  reason          String?       // RESIGNATION | TERMINATION_PERFORMANCE | TERMINATION_MISCONDUCT | MUTUAL | RETIREMENT | LAYOFF | END_OF_CONTRACT
  noticePeriodDays Int?         // typical 30
  // Timeline
  startDate       DateTime      @default(now())
  targetEndDate   DateTime?     // probation date for onboarding; last working day for offboarding
  actualEndDate   DateTime?
  // Roles
  buddyId         String?       // onboarding mentor (Employee.id)
  successorId     String?       // offboarding knowledge-transfer recipient (Employee.id)
  // Free-form
  notes           String?
  tasks           JourneyTask[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([type, status])
  @@map("employee_journeys")
}

model JourneyTask {
  id             String          @id @default(cuid())
  journeyId      String
  journey        EmployeeJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  category       String          // PAPERWORK | EQUIPMENT | SYSTEM_ACCESS | TRAINING | INTRO | EXIT_INTERVIEW | ASSET_RETURN | FNF | LEGAL | BUDDY
  phase          String          // PRE_DAY1 | DAY1 | WEEK1 | DAYS_30 | DAYS_60 | DAYS_90 | PROBATION_END | NOTICE | LAST_DAY | POST
  assignedToRole String?         // HR_ADMIN | MANAGER | IT | FINANCE | EMPLOYEE | BUDDY
  assignedToId   String?         // specific user id override
  dueDate        DateTime?
  status         String          @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | SKIPPED | BLOCKED
  completedAt    DateTime?
  completedBy    String?         // userId who marked it complete
  blocking       Boolean         @default(false) // must complete before next phase advances
  sortOrder      Int             @default(0)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([journeyId, phase, sortOrder])
  @@map("journey_tasks")
}

model EmailDraft {
  id            String    @id @default(cuid())
  employeeId    String?
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  toEmail       String
  toName        String?
  ccEmails      String?   // comma-separated
  bccEmails     String?   // comma-separated
  subject       String
  bodyHtml      String    // editable HTML body
  trigger       String    // OFFER_PERMANENT | OFFER_INTERN | CONFIRMATION | NOTICE_PERIOD | TERMINATION | OFFBOARDING_ACK | EXPERIENCE_LETTER | CUSTOM
  triggerRefId  String?   // journey id / task id / employee id for traceability
  status        String    @default("DRAFT") // DRAFT | APPROVED | SENT | REJECTED | FAILED
  createdById   String?
  approvedById  String?
  approvedAt    DateTime?
  sentAt        DateTime?
  sendError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

