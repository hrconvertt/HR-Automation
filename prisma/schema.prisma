  status      String          @default("ENROLLED") // ENROLLED | IN_PROGRESS | COMPLETED | FAILED
  score       Float?
  certificate String?
  notes       String?
  createdAt   DateTime        @default(now())

  @@map("training_records")
}

model Certification {
  id           String   @id @default(cuid())
  employeeId   String
  name         String
