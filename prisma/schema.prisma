}

model ExitInterview {
  id                String   @id @default(cuid())
  journeyId         String   @unique
  reasonText        String?  // free-text reason for leaving
  satisfactionScore Int?     // 1-5
  wouldRecommend    Int?     // 1-5 (NPS-ish)
  feedbackPositive  String?
  feedbackImprove   String?
  conductedById     String?  // userId
  conductedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("exit_interviews")
}

model ProbationRecord {
  id              String    @id @default(cuid())
  employeeId      String    @unique
  employee        Employee  @relation(fields: [employeeId], references: [id])
  startDate       DateTime
  endDate         DateTime
  durationMonths  Int       @default(3)
  performanceRating Float?
  managerNotes    String?
  outcome         String?   // legacy: CONFIRMED | EXTENDED | TERMINATED (still set on enact for back-compat)
  outcomeDate     DateTime?
  hrAlertSent     Boolean   @default(false)

  // ─── Devsinc-style lifecycle (full workflow) ───
  status                String   @default("ACTIVE") // ACTIVE | UNDER_REVIEW | CONFIRMED | EXTENDED | WARNED | TERMINATED
  // Day-30 settling check-in
  settlingCheckInAt     DateTime?
  settlingNotes         String?
  settlingFlag          String?  // GREEN | AMBER | RED
  // Decision packet (auto-generated at Day-(end-30))
  packetGeneratedAt     DateTime?
  packetDaysWorked      Int?
  packetDaysAbsent      Int?
  packetLateCount       Int?
  packetAvgHours        Float?
  packetGoalScore       Float?
  packetTimeScore       Float?
  packetSuggestedRec    String?  // CONFIRM | EXTEND | TERMINATE
  // Manager review
  managerRecommendation String?  // CONFIRM | EXTEND | TERMINATE
  managerReviewNotes    String?
  managerSubmittedAt    DateTime?
  // HR decision
  hrDecision            String?  // CONFIRM | EXTEND | WARNING | TERMINATE
  hrNotes               String?
  hrDecidedAt           DateTime?
  hrDecidedById         String?
  extensionMonths       Int?
  overrodeManager       Boolean  @default(false)
  // Decision meeting
  meetingScheduledFor   DateTime?
  meetingAgenda         String?
  // Outcome
  outcomeEnactedAt      DateTime?
  confirmationLetterId  String?
  isEarlyDecision       Boolean  @default(false)
  earlyDecisionReason   String?
  // Warning
  warningIssuedAt       DateTime?
  warningNotes          String?
  warningCount          Int      @default(0)
  // Extension cap (max 2) + new reminder cadence touch-points
  extensionCount        Int      @default(0)
  heads45NotifiedAt     DateTime?
  urgent14NotifiedAt    DateTime?
  // Optional salary bump on confirm
  salaryBumpAmount      Float?
  salaryBumpEffective   DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("probation_records")
}

// ─── RECRUITING ───────────────────────────────────────────────────────────────

model JobRequisition {
  id             String      @id @default(cuid())
  title          String
  departmentId   String?
  positionLevel  String?
  type           String      // FULL_TIME | PART_TIME | INTERNSHIP | TRAINEE | CONTRACT
  vacancies      Int         @default(1)
  description    String?
  requirements   String?
  salaryMin      Float?
  salaryMax      Float?
  postedDate     DateTime?
  closingDate    DateTime?
  status         String      @default("OPEN") // PENDING | OPEN | PAUSED | CLOSED | FILLED | REJECTED
  requestedById  String?     // Manager (Employee.id) who raised the request, if any
  requestedBy    Employee?   @relation("HiringRequests", fields: [requestedById], references: [id])
  requestReason  String?     // REPLACEMENT | GROWTH | BACKFILL | OTHER — picked by the manager
  requestNote    String?     // Manager's free-text justification
  decisionNote   String?     // HR's approval / rejection comment
  decidedAt      DateTime?
  decidedById    String?     // HR User.id who approved or rejected

  // ─── Job Description workflow (Phase A of recruiting AI) ─────────
  //   Status spectrum: DRAFT_JD → JD_APPROVED → POSTED
  //   Auto-generated when HR approves a hiring request, then HR can
  //   edit before sending to LinkedIn/Indeed (or the public /careers page).
  jdContent      String?    // Markdown body of the job description
  jdStatus       String?    // DRAFT_JD | JD_APPROVED | POSTED (null = not generated yet)
  jdGeneratedAt  DateTime?
  jdApprovedAt   DateTime?
  jdApprovedById String?

  // Per-role score threshold (0-100). Candidates scoring at/above
  // this number qualify for auto talent-pool inclusion. Default 60.
  scoreThreshold Int        @default(60)

  candidates     Candidate[]
  knockoutCriteria KnockoutCriterion[]
  isDemo         Boolean    @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("job_requisitions")
}

// ─── KNOCKOUT FILTERS ──────────────────────────────────────────────────────────
// Per-requisition hard/soft filter criteria. Applied at application intake
// BEFORE the candidate is scored — failed candidates get knockoutStatus=FAILED
// and skip AI scoring entirely.
model KnockoutCriterion {
  id              String   @id @default(cuid())
  requisitionId   String
  requisition     JobRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  // WORK_AUTH | LOCATION | SKILL | MIN_YEARS | MIN_EDUCATION | LANGUAGE
  type            String
  // Interpreted per type — see src/lib/knockout-evaluator.ts
  value           String
  isHard          Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([requisitionId])
  @@map("knockout_criteria")
}

model Candidate {
  id              String         @id @default(cuid())
  requisitionId   String
  requisition     JobRequisition @relation(fields: [requisitionId], references: [id])
  fullName        String
  email           String
  phone           String?
  cnic            String?
  currentCompany  String?
  currentRole     String?
  experience      Float?
  cvUrl           String?
  stage           String         @default("APPLIED") // APPLIED | SCREENING | INTERVIEW | OFFER | HIRED | REJECTED
  source          String?        // REFERRAL | LINKEDIN | PORTAL | WALK_IN | CAREERS_PAGE | OTHER
  notes           String?
  // Phase C — auto-scored on create + when JD updates.
  // 0–100. >=70 = strong match, 50-69 = worth a call, <50 = filter out.
  matchScore      Float?
  scoreReason     String?        // Short JSON-ish explainer of what added/subtracted

  // Talent Pool — keep strong candidates around even after a rejection.
  // Filled automatically (REJECTED + score>=60) or manually by HR.
  inTalentPool    Boolean   @default(false)
  poolTags        String?   // comma-separated: "UI/UX,Senior,Trusted,Available"
  poolReason      String?   // why they're in the pool (auto or manual note)
  poolAddedAt     DateTime?
  lastStallNotifiedAt DateTime?

  // ─── Workday-style knockout filter pipeline ────────────────────────
  //   PENDING    — evaluator hasn't run yet (default for legacy rows)
  //   PASSED     — meets all hard criteria for the requisition
  //   FAILED     — failed at least one hard criterion, scoring skipped
  //   OVERRIDDEN — HR manually overrode a FAILED result; gets scored
  knockoutStatus         String    @default("PENDING")
  knockoutReasons        String?   // JSON array of {type, reason}
  knockoutOverrideBy     String?
  knockoutOverrideReason String?
  knockoutOverrideAt     DateTime?

  // Knockout filter inputs collected on the apply form
  workAuthorization String?  // country code, e.g. "PK"
  yearsExperience   Int?
  educationLevel    String?  // HIGH_SCHOOL | DIPLOMA | BACHELORS | MASTERS | PHD
  location          String?
  openToRemote      Boolean  @default(false)
  skills            String?  // JSON array of strings
  languages         String?  // JSON array of strings

  interviews      Interview[]
  offer           JobOffer?
  isDemo          Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("candidates")
}

model Interview {
  id            String    @id @default(cuid())
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  round         Int       @default(1)
  type          String    // PHONE | VIDEO | ONSITE | TECHNICAL | HR
  scheduledAt   DateTime
  duration      Int       // minutes
  interviewerIds String?  // JSON array of employee IDs
  meetingLink   String?   // Optional Google Meet / Zoom URL — HR pastes manually
  notes         String?   // pre-interview notes / location / what to bring
  feedback      String?
  rating        Float?
  result        String?   // PASS | FAIL | HOLD
  createdAt     DateTime  @default(now())

  @@map("interviews")
}

model JobOffer {
  id           String    @id @default(cuid())
  candidateId  String    @unique
  candidate    Candidate @relation(fields: [candidateId], references: [id])
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id])
  offerDate    DateTime
  salary       Float
  joiningDate  DateTime?
  status       String    @default("PENDING") // PENDING | ACCEPTED | REJECTED | EXPIRED | WITHDRAWN
  statusChangedAt DateTime?
  rejectionReason String?
  letterUrl    String?
  expiryDate   DateTime?
  createdAt    DateTime  @default(now())

  @@map("job_offers")
}

// ─── LEARNING & DEVELOPMENT ───────────────────────────────────────────────────

model TrainingProgram {
  id          String          @id @default(cuid())
