    "// Production one-time seed — runs after the first deploy lands": "",
    "seed:prod": "node scripts/seed-production.js",
    "seed": "npx ts-node --project tsconfig.json src/lib/seed.ts",
    "db:seed": "npx tsx src/lib/seed.ts",
    "import": "npx ts-node --project tsconfig.json scripts/import-employees.ts",
    "db:studio": "npx prisma studio",
    "db:migrate": "npx prisma migrate dev"
