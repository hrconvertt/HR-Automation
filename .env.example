# ─── Convertt HR — Environment variables ──────────────────────────────
# Copy this file to .env.local for local development.
# In Vercel, set these in: Settings → Environment Variables.

# ─── Database ──────────────────────────────────────────────────────────
# Postgres connection string. On Vercel, this is auto-injected when you
# add Vercel Postgres to the project. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
DATABASE_URL="postgres://user:password@localhost:5432/convertt_hr?sslmode=require"

# ─── Auth ──────────────────────────────────────────────────────────────
# Random secret used to sign JWTs. MUST be at least 16 characters in prod.
# Generate one with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-string-min-16-chars"

# ─── App ───────────────────────────────────────────────────────────────
# Public URL of the deployed app. Used by the JD generator, the careers
# RSS feed, and email link generation. Include the protocol.
#   Local:       http://localhost:3000
#   Vercel prev: https://convertt-hr-git-<branch>-convertt.vercel.app
#   Production:  https://hr.convertt.co
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Optional ──────────────────────────────────────────────────────────
# Focus Mode hides modules under polishing. Default ON in production
# until all modules are polished — flip to "false" to show everything.
# NEXT_PUBLIC_FOCUS_MODE="true"

# Anthropic API key — when set, the JD generator and candidate-scoring
# helpers can call Claude instead of using the deterministic templates.
# Leave unset to keep the current rule-based behaviour.
# ANTHROPIC_API_KEY=""
